{
  "name": "@ludoteca/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "prebuild": "pnpm --filter @ludoteca/shared build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @ludoteca/shared build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "start:migrate": "node dist/db/migrate.js && pnpm start",
    "test": "node --env-file=../../.env --import tsx --test \"src/**/*.test.ts\"",
    "db:generate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:migrate:prod": "node --env-file-if-exists=../../.env dist/db/migrate.js",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts",
    "db:studio": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@fastify/autoload": "6.4.0",
    "@fastify/cookie": "11.1.2",
    "@fastify/cors": "11.3.0",
    "@fastify/csrf-protection": "8.0.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/jwt": "10.2.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/sensible": "6.0.4",
    "@ludoteca/shared": "workspace:*",
    "argon2": "0.44.0",
    "close-with-grace": "2.5.0",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "fastify-type-provider-zod": "7.0.0",
    "nanoid": "6.0.0",
    "postgres": "3.4.9",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
