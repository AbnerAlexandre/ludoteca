# ---------------------------------------------------------------------------
# Ludoteca — backend-only configuration.
# Copy to `.env` and fill in. NEVER commit `.env`, never expose these to the
# browser: the web app receives only sanitized responses from the API.
# ---------------------------------------------------------------------------

# Ludopedia API — SERVER-SIDE ONLY.
LUDOPEDIA_APP_ID=
LUDOPEDIA_APP_KEY=
LUDOPEDIA_ACCESS_TOKEN=
LUDOPEDIA_BASE_URL=https://ludopedia.com.br/api/v1
LUDOPEDIA_TIMEOUT_MS=8000
LUDOPEDIA_CACHE_TTL_HOURS=168

# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ludoteca
WEB_ORIGIN=http://localhost:4200

# Secrets — generate with: node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
COOKIE_SECRET=change-me-to-another-long-random-string

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Google OAuth — leave empty; the flow stays disabled until FEATURE_GOOGLE_OAUTH=true
FEATURE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Postgres container (docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ludoteca
# Host port for the container. Defaults to 5433 to avoid colliding with a
# Postgres you may already have on the standard 5432.
POSTGRES_PORT=5433
