{
  "name": "ludoteca",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter @ludoteca/api dev",
    "dev:web": "pnpm --filter @ludoteca/web dev",
    "build": "pnpm --filter @ludoteca/shared build && pnpm --parallel --filter \"./apps/*\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @ludoteca/api db:generate",
    "db:migrate": "pnpm --filter @ludoteca/api db:migrate",
    "db:seed": "pnpm --filter @ludoteca/api db:seed",
    "db:studio": "pnpm --filter @ludoteca/api db:studio",
    "audit": "pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
